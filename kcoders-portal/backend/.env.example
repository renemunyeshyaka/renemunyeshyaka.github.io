# Application Name
APP_NAME=Kcoders Portal

# Database (docker-compose defaults)
DB_HOST=localhost
DB_PORT=5433
DB_USER=kcoders
DB_PASSWORD=your_password
DB_NAME=kcoders_db

# Alternatively, use a full connection string (overrides individual vars above)
# DATABASE_URL=host=localhost port=5432 user=kcoders password=your_password dbname=kcoders_db sslmode=disable TimeZone=Africa/Kigali

# JWT
JWT_SECRET=change_me_to_a_random_secret

# TOTP / OTP
TOTP_ISSUER=Kcoders.org

# SMTP (email sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@kcoders.org

# Server Configuration
PORT=5003

# Frontend URL (used in email links, password reset, etc.)
FRONTEND_URL=http://localhost:3003
